generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  auditLogs AuditLog[]

  @@map("users")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id      String           @id @default(cuid())
  action  String
  subject String
  roles   RolePermission[]

  @@unique([action, subject])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Department {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  positions Position[]
  employees Employee[]

  @@map("departments")
}

model Branch {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  positions Position[]
  employees Employee[]

  @@map("branches")
}

model JobLevel {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  order     Int
  positions Position[]
  employees Employee[]

  @@map("job_levels")
}

model Position {
  id            String     @id @default(cuid())
  code          String     @unique
  name          String
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id])
  branchId      String
  branch        Branch     @relation(fields: [branchId], references: [id])
  jobLevelId    String
  jobLevel      JobLevel   @relation(fields: [jobLevelId], references: [id])
  salaryMin     Decimal    @db.Decimal(12, 2)
  salaryMax     Decimal    @db.Decimal(12, 2)
  status        PositionStatus @default(active)
  description   String?    @db.Text
  requirements  String?    @db.Text
  notes         String?    @db.Text
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  employees     Employee[]
  recruitmentJobs RecruitmentJob[]

  @@map("positions")
}

enum PositionStatus {
  active
  inactive
  recruiting
}

model Employee {
  id           String     @id @default(cuid())
  code         String     @unique
  firstName    String
  lastName     String
  email        String     @unique
  phone        String?
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  positionId   String
  position     Position   @relation(fields: [positionId], references: [id])
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id])
  jobLevelId   String
  jobLevel     JobLevel   @relation(fields: [jobLevelId], references: [id])
  hireDate     DateTime
  status       EmployeeStatus @default(active)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  payrollRecords    PayrollRecord[]
  overtimeRequests  OvertimeRequest[]
  assets            Asset[]

  @@map("employees")
}

enum EmployeeStatus {
  active
  inactive
  resigned
  terminated
}

model AttendanceRecord {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  date       DateTime @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     String
  note       String?
  createdAt  DateTime @default(now())

  @@map("attendance_records")
}

model LeaveRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  leaveType  String
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  days       Decimal  @db.Decimal(4, 1)
  reason     String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("leave_requests")
}

model PayrollRecord {
  id           String   @id @default(cuid())
  employeeId   String
  employee     Employee @relation(fields: [employeeId], references: [id])
  month        Int
  year         Int
  baseSalary   Decimal  @db.Decimal(12, 2)
  overtime     Decimal  @db.Decimal(12, 2) @default(0)
  commission   Decimal  @db.Decimal(12, 2) @default(0)
  deductions   Decimal  @db.Decimal(12, 2) @default(0)
  netPay       Decimal  @db.Decimal(12, 2)
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeId, month, year])
  @@map("payroll_records")
}

model OvertimeRequest {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])
  date       DateTime @db.Date
  hours      Decimal  @db.Decimal(4, 2)
  reason     String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("overtime_requests")
}

model RecruitmentJob {
  id         String     @id @default(cuid())
  positionId String
  position   Position   @relation(fields: [positionId], references: [id])
  openings   Int
  status     String     @default("open")
  closedAt   DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  applicants Applicant[]

  @@map("recruitment_jobs")
}

model Applicant {
  id              String         @id @default(cuid())
  recruitmentJobId String
  recruitmentJob  RecruitmentJob @relation(fields: [recruitmentJobId], references: [id])
  firstName       String
  lastName        String
  email           String
  phone           String?
  resumeUrl       String?
  status          String         @default("applied")
  appliedAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("applicants")
}

model Asset {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  category   String
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id])
  status     String   @default("available")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("assets")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  targetRole String?
  publishedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entity     String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
